                }
              }
            },
            {
              "id": "ppcc42",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We may update this Privacy Policy from time to time. The updated version will be indicated by an updated \"Last Updated\" date at the top of this page.</p>"
              }
            },
