          "elements": [
            {
              "id": "ppcc03",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:24px;\"><strong>Regal Plumbing &amp; Rooter</strong><br>2141 E Philadelphia St, Suite R, Ontario, CA 91761 &nbsp;|&nbsp; <a href=\"tel:9096004561\">(909) 600-4561</a> &nbsp;|&nbsp; <a href=\"mailto:info@regalplumbingservices.com\">info@regalplumbingservices.com</a></p>"
              }
            },
            {
              "id": "ppcc10",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "1. Introduction",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc30",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">Regal Plumbing &amp; Rooter (\"we,\" \"us,\" or \"our\") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website or contact us for plumbing services.</p>"
              }
            },
            {
              "id": "ppcc11",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "2. Information We Collect",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc31",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\"><strong>Personal Data:</strong> Name, email address, phone number, city, and service information you voluntarily provide when submitting a contact form or calling us.<br><strong>Derivative Data:</strong> Information our servers automatically collect when you visit our website, such as your IP address, browser type, and access times.<br><strong>Mobile Device Data:</strong> Device hardware model, operating system, and mobile network information if you access via a mobile device.</p>"
              }
            },
            {
              "id": "ppcc12",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "3. Contact Forms",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc32",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">When you submit a contact form, we collect your name, phone number, email, city, service needed, and message. This information is used solely to respond to your inquiry and schedule service. We do not sell or rent this information to third parties. Form submissions are sent to info@regalplumbingservices.com.</p>"
              }
            },
            {
              "id": "ppcc13",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "4. Cookies and Tracking",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc33",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We may use cookies and tracking technologies to improve your experience. Most browsers accept cookies by default. You can disable cookies in your browser settings, which may affect website functionality.</p>"
              }
            },
            {
              "id": "ppcc14",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "5. Google Analytics",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc34",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We use Google Analytics to analyze traffic patterns on our website. Google Analytics collects information about how often users visit the site and what pages they view. You can opt out by installing the Google Analytics Opt-out Browser Add-on.</p>"
              }
            },
            {
              "id": "ppcc15",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "6. Third-Party Services",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc35",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We may share your information with email delivery services, Google Maps, and web hosting and analytics providers. These third parties have access only to perform their specific functions.</p>"
              }
            },
            {
              "id": "ppcc16",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "7. How We Use Your Information",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc36",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We use your information to: respond to service inquiries and schedule appointments; email or call you regarding your service request; monitor usage trends to improve our website; and comply with legal obligations.</p>"
              }
            },
            {
              "id": "ppcc17",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "8. Disclosure of Your Information",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc37",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We do not sell, trade, or transfer your personally identifiable information to outside parties, except as required by law or in connection with a business transfer.</p>"
              }
            },
            {
              "id": "ppcc18",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "9. Security",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc38",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We use administrative, technical, and physical security measures to help protect your personal information. No security measures are perfect, but we take reasonable steps to safeguard your data.</p>"
              }
            },
            {
              "id": "ppcc19",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "10. Your Rights",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc39",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">You may request a copy of, correction of, or deletion of your personal information. California residents have additional rights under CCPA. Contact us at info@regalplumbingservices.com or (909) 600-4561 to exercise these rights.</p>"
              }
            },
            {
              "id": "ppcc20",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "11. California Privacy Rights (CCPA)",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc40",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">California residents have the right to know what personal information we collect, the right to delete personal information, the right to opt-out of the sale of personal information (we do not sell your information), and the right to non-discrimination.</p>"
              }
            },
            {
              "id": "ppcc21",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "12. Children's Privacy",
                "header_size": "h2",
                "typography_font_family": "Oswald",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 22
                },
                "title_color": "#1E3A6E",
                "_margin": {
                  "unit": "px",
                  "top": "24",
                  "right": "0",
                  "bottom": "8",
                  "left": "0",
                  "isLinked": false
                }
              }
            },
            {
              "id": "ppcc41",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">Our website is not directed to children under 13. We do not knowingly collect personal information from children under 13.</p>"
              }
            },
            {
              "id": "ppcc22",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "13. Changes to This Policy",
                "header_size": "h2",
