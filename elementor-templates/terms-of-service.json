            {
              "id": "tscc43",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:16px;\">We provide upfront, transparent pricing before any work begins. Final pricing may vary if hidden damage is discovered, additional materials are required, or permits are needed. We will notify you of any changes before proceeding.</p>"
